# Terraform working directory
.terraform/

# Terraform state files
*.tfstate
*.tfstate.*

# Crash log files
crash.log

# Terraform CLI configuration files
.terraformrc
terraform.rc

# Terraform lock file 
.terraform.lock.hcl

# Variables files containing secrets
*.tfvars
*.tfvars.json
*.terraform.tfvars

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Sensitive data
*.pem
*.key
*.pub
*.pfx
*.p12

# SSH keys
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub

# Yandex Cloud keys
*.json

# Ansible generated inventory
inventory.ini
ansible.cfg
inventory.yml
*.retry

# Logs
*.log

# Python
__pycache__/
*.py[cod]
*$py.class

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Python virtual environments (если используется ansible)
venv/
.env/

# Temporary files
*.tmp
*.bak
*.swp
*.vault_pass
.vault_pass

# Secrets
group_vars/*vault.yml
host_vars/*vault.yml
!group_vars/.gitkeep
!host_vars/.gitkeep