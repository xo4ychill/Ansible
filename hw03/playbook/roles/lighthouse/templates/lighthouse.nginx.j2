# =============================================================================
# Nginx configuration for Lighthouse
# Назначение: отдача статики, логирование, базовая HTTP-безопасность
# =============================================================================

server {
    listen {{ lighthouse_nginx_port }};
    listen [::]:{{ lighthouse_nginx_port }} default_server;
    server_name {{ lighthouse_nginx_server_name }};

    root {{ lighthouse_nginx_root }};
    index index.html;

    # 📝 Логи доступа и ошибок (отдельно для этого сайта)
    access_log {{ lighthouse_nginx_log_dir }}/access.log;
    error_log {{ lighthouse_nginx_log_dir }}/error.log;

    # 🗂️ Отдача статики
    location / {
        try_files $uri $uri/ =404;
        autoindex off;
    }

    # 🔄 Проксирование API (заготовка для будущего расширения)
    # location /api {
    #     proxy_pass http://backend;
    #     proxy_set_header Host $host;
    #     proxy_set_header X-Real-IP $remote_addr;
    # }

    # 🛡️ Security Headers (защита от XSS, clickjacking, MIME-sniffing)
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;

    # 🗑️ Скрытие версии Nginx в заголовках ответов
    server_tokens off;

    # 🗑️ Отключить логи для статики (опционально)
    # location ~* \.(jpg|jpeg|png|gif|ico|css|js)$ {
    #     access_log off;
    #     expires 30d;
    # }
}
