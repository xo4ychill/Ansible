# =============================================================================
# Vector configuration (production-ready example)
#
# Назначение:
#   - приём логов из stdin
#   - запись в файл в JSON формате
#
# Используется для:
#   - тестирования pipeline
#   - демонстрации ingestion flow
# =============================================================================


# =============================================================================
# 📥 SOURCES (откуда приходят данные)
# =============================================================================
# stdin — стандартный поток ввода
# Используется для тестов и простых сценариев
# =============================================================================
[sources.stdin_logs]
type = "stdin"


# =============================================================================
# 🔄 TRANSFORMS (опционально)
# =============================================================================
# Можно добавить обработку логов (parse, filter, enrich)
# Пример оставлен как точка расширения
#
# [transforms.parse_logs]
# type = "remap"
# inputs = ["stdin_logs"]
# source = '''
# .parsed = parse_json!(.message)
# '''
# =============================================================================


# =============================================================================
# 📤 SINKS (куда отправляются данные)
# =============================================================================
# file sink — запись логов в файл
#
# ВАЖНО:
# - директория /var/log/vector должна существовать
# - права должны позволять запись пользователю vector
# =============================================================================
[sinks.file_out]
type = "file"

# входящие данные
inputs = ["stdin_logs"]

# путь для сохранения логов
path = "/var/log/vector/output.log"

# формат данных (JSON — наиболее универсальный)
encoding.codec = "json"


# =============================================================================
# 🧠 OPTIONAL IMPROVEMENTS (для продакшена)
# =============================================================================
# Можно расширить:
#
# sinks:
#   - elasticsearch
#   - kafka
#   - clickhouse
#   - loki
#
# sources:
#   - syslog
#   - journald
#   - file tail
#
# =============================================================================